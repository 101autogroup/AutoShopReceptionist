<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-surface-50">Your Agents</h1>
    <p class="text-surface-400 mt-1">Voice agents assigned to your account</p>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-center gap-3">
    <a href="/agent-change-requests" class="btn btn-primary">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14m7-7H5"/>
      </svg>
      Request Agent Change
    </a>
    <p class="text-xs text-surface-400 sm:ml-auto">
      Submit your change request; an admin will complete it.
    </p>
  </div>

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  <!-- Agents Grid -->
  ${agents.length === 0 ? `
  <div class="card text-center py-16">
    <svg class="w-16 h-16 mx-auto mb-4 text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
    </svg>
    <h3 class="text-lg font-medium text-surface-200 mb-2">No agents assigned</h3>
    <p class="text-surface-400">Contact your administrator to get agents assigned to your account.</p>
  </div>
  ` : `
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    ${agents.map(agent => `
    <div class="card hover:border-surface-700 transition-colors">
      <div class="flex items-start justify-between mb-4">
        <div class="w-12 h-12 rounded-xl bg-brand-600/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        ${agent.is_published ? `
        <span class="badge badge-success">Published</span>
        ` : `
        <span class="badge">Draft</span>
        `}
      </div>
      
      <h3 class="text-lg font-semibold text-surface-100 mb-1">
        ${agent.agent_name || 'Unnamed Agent'}
      </h3>
      <p class="text-sm text-surface-400 font-mono mb-4">${agent.agent_id.substring(0, 16)}...</p>
      
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-surface-400">Voice</span>
          <span class="text-surface-200">${agent.voice_id || 'Default'}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-surface-400">Language</span>
          <span class="text-surface-200">${agent.language || 'en-US'}</span>
        </div>
        ${agent.response_engine ? `
        <div class="flex justify-between">
          <span class="text-surface-400">Engine</span>
          <span class="text-surface-200 capitalize">${agent.response_engine.type || 'N/A'}</span>
        </div>
        ` : ''}
      </div>
      
      <div class="mt-6 pt-4 border-t border-surface-800">
        <a href="/agents/${agent.agent_id}" class="btn btn-secondary w-full">
          View Details
        </a>
      </div>
    </div>
    `).join('')}
  </div>
  `}
</div>
` }) %>

