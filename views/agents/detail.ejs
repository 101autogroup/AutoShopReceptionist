<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Back link -->
  <a href="/agents" class="inline-flex items-center gap-2 text-surface-400 hover:text-surface-200 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Agents
  </a>

  <!-- Header -->
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-4">
      <div class="w-16 h-16 rounded-2xl bg-brand-600/10 flex items-center justify-center">
        <svg class="w-8 h-8 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-surface-50">${agent.agent_name || 'Unnamed Agent'}</h1>
        <p class="text-surface-400 font-mono text-sm mt-1">${agent.agent_id}</p>
      </div>
    </div>
    <div>
      ${agent.is_published ? `
      <span class="badge badge-success text-base px-4 py-2">Published</span>
      ` : `
      <span class="badge text-base px-4 py-2">Draft</span>
      `}
    </div>
  </div>

  <!-- Quick Stats -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="stat-card">
      <div class="stat-label">Voice</div>
      <div class="text-lg font-semibold text-surface-100 mt-1">${agent.voice_id || 'Default'}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Language</div>
      <div class="text-lg font-semibold text-surface-100 mt-1">${agent.language || 'en-US'}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Voice Speed</div>
      <div class="text-lg font-semibold text-surface-100 mt-1">${agent.voice_speed || 1}x</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Responsiveness</div>
      <div class="text-lg font-semibold text-surface-100 mt-1">${agent.responsiveness || 1}</div>
    </div>
  </div>

  <!-- Details -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Voice Settings -->
    <div class="card">
      <h2 class="text-lg font-semibold text-surface-100 mb-4">Voice Settings</h2>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-surface-400">Voice Model</dt>
          <dd class="text-surface-200">${agent.voice_model || 'N/A'}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Voice Temperature</dt>
          <dd class="text-surface-200">${agent.voice_temperature || 1}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Volume</dt>
          <dd class="text-surface-200">${agent.volume || 1}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Backchannel</dt>
          <dd class="text-surface-200">${agent.enable_backchannel ? 'Enabled' : 'Disabled'}</dd>
        </div>
        ${agent.ambient_sound ? `
        <div class="flex justify-between">
          <dt class="text-surface-400">Ambient Sound</dt>
          <dd class="text-surface-200 capitalize">${agent.ambient_sound}</dd>
        </div>
        ` : ''}
      </dl>
    </div>

    <!-- Call Settings -->
    <div class="card">
      <h2 class="text-lg font-semibold text-surface-100 mb-4">Call Settings</h2>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-surface-400">Interruption Sensitivity</dt>
          <dd class="text-surface-200">${agent.interruption_sensitivity || 1}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Reminder Trigger</dt>
          <dd class="text-surface-200">${agent.reminder_trigger_ms ? (agent.reminder_trigger_ms / 1000) + 's' : 'N/A'}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Max Call Duration</dt>
          <dd class="text-surface-200">${agent.max_call_duration_ms ? Math.round(agent.max_call_duration_ms / 60000) + ' min' : 'N/A'}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">End After Silence</dt>
          <dd class="text-surface-200">${agent.end_call_after_silence_ms ? Math.round(agent.end_call_after_silence_ms / 60000) + ' min' : 'N/A'}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">STT Mode</dt>
          <dd class="text-surface-200 capitalize">${agent.stt_mode || 'N/A'}</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Response Engine -->
  ${agent.response_engine ? `
  <div class="card">
    <h2 class="text-lg font-semibold text-surface-100 mb-4">Response Engine</h2>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-surface-400">Type</dt>
        <dd class="text-surface-200 capitalize">${agent.response_engine.type}</dd>
      </div>
      ${agent.response_engine.llm_id ? `
      <div class="flex justify-between">
        <dt class="text-surface-400">LLM ID</dt>
        <dd class="text-surface-200 font-mono text-sm">${agent.response_engine.llm_id}</dd>
      </div>
      ` : ''}
    </dl>
  </div>
  ` : ''}

  <!-- Boosted Keywords -->
  ${agent.boosted_keywords && agent.boosted_keywords.length > 0 ? `
  <div class="card">
    <h2 class="text-lg font-semibold text-surface-100 mb-4">Boosted Keywords</h2>
    <div class="flex flex-wrap gap-2">
      ${agent.boosted_keywords.map(kw => `
      <span class="badge badge-info">${kw}</span>
      `).join('')}
    </div>
  </div>
  ` : ''}
</div>
` }) %>

