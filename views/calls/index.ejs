<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-surface-50">Call History</h1>
    <p class="text-surface-400 mt-1">View and listen to call recordings</p>
  </div>

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  <!-- Filters -->
  <div class="card">
    <form action="/calls" method="GET" class="flex flex-wrap gap-4">
      <div class="flex-1 min-w-[180px]">
        <label class="label">Agent</label>
        <select name="agent" class="input">
          <option value="">All Agents</option>
          ${agents.map(a => `
            <option value="${a.agent_id}" ${filters.agent === a.agent_id ? 'selected' : ''}>
              ${a.agent_name || a.agent_id.substring(0, 12)}
            </option>
          `).join('')}
        </select>
      </div>

      <div class="flex-1 min-w-[180px]">
        <label class="label">Status</label>
        <select name="status" class="input">
          <option value="">All Statuses</option>
          <option value="successful" ${filters.status === 'successful' ? 'selected' : ''}>Successful</option>
          <option value="unsuccessful" ${filters.status === 'unsuccessful' ? 'selected' : ''}>Unsuccessful</option>
          <option value="unknown" ${filters.status === 'unknown' ? 'selected' : ''}>Unknown</option>
        </select>
      </div>

      <div class="flex-1 min-w-[150px]">
        <label class="label">Start Date</label>
        <input type="date" name="startDate" value="${filters.startDate || ''}" class="input">
      </div>

      <div class="flex-1 min-w-[150px]">
        <label class="label">End Date</label>
        <input type="date" name="endDate" value="${filters.endDate || ''}" class="input">
      </div>

      <div class="flex items-end gap-2">
        <button type="submit" class="btn btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Filter
        </button>
        <a href="/calls" class="btn btn-secondary">Clear</a>
      </div>
    </form>
  </div>

  <!-- Results count -->
  <div class="flex items-center justify-between">
    <p class="text-sm text-surface-400">
      Showing ${calls.length} of ${pagination.total} calls
    </p>
  </div>

  <!-- Calls Table -->
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Agent</th>
          <th>Duration</th>
          <th>Direction</th>
          <th>Status</th>
          <th>Sentiment</th>
          <th>Recording</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        ${calls.length === 0 ? `
        <tr>
          <td colspan="8" class="text-center py-12 text-surface-400">
            <svg class="w-12 h-12 mx-auto mb-4 text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            No calls found
          </td>
        </tr>
        ` : calls.map(call => `
        <tr>
          <td class="whitespace-nowrap">
            <span class="text-surface-100">${call.formattedDate}</span>
          </td>
          <td>
            <span class="font-medium text-surface-200">${call.agentName}</span>
          </td>
          <td class="text-surface-300">
            ${formatDuration(call.duration)}
          </td>
          <td>
            <span class="badge ${call.direction === 'inbound' ? 'badge-info' : 'badge-warning'}">
              ${call.direction || 'N/A'}
            </span>
          </td>
          <td>
            ${call.call_successful === true ? '<span class="badge badge-success">Successful</span>' : 
              call.call_successful === false ? '<span class="badge badge-error">Unsuccessful</span>' :
              '<span class="badge">Unknown</span>'}
          </td>
          <td>
            ${call.user_sentiment ? `
            <span class="badge ${
              call.user_sentiment.toLowerCase() === 'positive' ? 'badge-success' :
              call.user_sentiment.toLowerCase() === 'negative' ? 'badge-error' :
              'badge-warning'
            }">
              ${call.user_sentiment}
            </span>
            ` : '<span class="text-surface-500">-</span>'}
          </td>
          <td>
            ${call.recording_url ? `
            <audio controls class="h-8 w-36">
              <source src="${call.recording_url}" type="audio/mpeg">
            </audio>
            ` : '<span class="text-surface-500">-</span>'}
          </td>
          <td>
            <a href="/calls/${call.call_id}" class="text-brand-400 hover:text-brand-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </td>
        </tr>
        `).join('')}
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  ${pagination.totalPages > 1 ? `
  <div class="flex items-center justify-center gap-2">
    ${pagination.page > 1 ? `
    <a href="/calls?page=${pagination.page - 1}&agent=${filters.agent || ''}&status=${filters.status || ''}&startDate=${filters.startDate || ''}&endDate=${filters.endDate || ''}" class="btn btn-secondary">
      Previous
    </a>
    ` : ''}
    
    <span class="px-4 py-2 text-surface-400">
      Page ${pagination.page} of ${pagination.totalPages}
    </span>
    
    ${pagination.page < pagination.totalPages ? `
    <a href="/calls?page=${pagination.page + 1}&agent=${filters.agent || ''}&status=${filters.status || ''}&startDate=${filters.startDate || ''}&endDate=${filters.endDate || ''}" class="btn btn-secondary">
      Next
    </a>
    ` : ''}
  </div>
  ` : ''}
</div>
` }) %>

