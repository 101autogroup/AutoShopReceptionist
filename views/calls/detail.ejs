<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Back link -->
  <a href="/calls" class="inline-flex items-center gap-2 text-surface-400 hover:text-surface-200 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Calls
  </a>

  <!-- Header -->
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-surface-50">Call Details</h1>
      <p class="text-surface-400 mt-1">${call.formattedStartDate}</p>
    </div>
    <div>
      ${call.call_successful === true ? '<span class="badge badge-success text-base px-4 py-2">Successful</span>' : 
        call.call_successful === false ? '<span class="badge badge-error text-base px-4 py-2">Unsuccessful</span>' :
        '<span class="badge text-base px-4 py-2">Unknown</span>'}
    </div>
  </div>

  <!-- Overview Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="stat-card">
      <div class="stat-label">Agent</div>
      <div class="text-xl font-semibold text-surface-100 mt-1">${call.agentName}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Duration</div>
      <div class="text-xl font-semibold text-surface-100 mt-1">${formatDuration(call.duration)}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Direction</div>
      <div class="text-xl font-semibold text-surface-100 mt-1 capitalize">${call.direction || 'N/A'}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Latency</div>
      <div class="text-xl font-semibold text-surface-100 mt-1">${call.latency_p50 ? call.latency_p50 + 'ms' : 'N/A'}</div>
    </div>
  </div>

  <!-- Recording -->
  ${call.recording_url ? `
  <div class="card">
    <h2 class="text-lg font-semibold text-surface-100 mb-4">Recording</h2>
    <audio controls class="w-full">
      <source src="${call.recording_url}" type="audio/mpeg">
      Your browser does not support the audio element.
    </audio>
    <div class="mt-4">
      <a href="${call.recording_url}" target="_blank" download class="btn btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download Recording
      </a>
    </div>
  </div>
  ` : ''}

  <!-- Details Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Call Info -->
    <div class="card">
      <h2 class="text-lg font-semibold text-surface-100 mb-4">Call Information</h2>
      <dl class="space-y-4">
        <div class="flex justify-between">
          <dt class="text-surface-400">Call ID</dt>
          <dd class="text-surface-200 font-mono text-sm">${call.call_id}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Start Time</dt>
          <dd class="text-surface-200">${call.formattedStartDate}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">End Time</dt>
          <dd class="text-surface-200">${call.formattedEndDate}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Answered By</dt>
          <dd class="text-surface-200 capitalize">${call.answered_by || 'N/A'}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Disconnection Reason</dt>
          <dd class="text-surface-200">${call.disconnection_reason || 'N/A'}</dd>
        </div>
      </dl>
    </div>

    <!-- Analysis -->
    <div class="card">
      <h2 class="text-lg font-semibold text-surface-100 mb-4">Analysis</h2>
      <dl class="space-y-4">
        <div class="flex justify-between">
          <dt class="text-surface-400">User Sentiment</dt>
          <dd>
            ${call.user_sentiment ? `
            <span class="badge ${
              call.user_sentiment.toLowerCase() === 'positive' ? 'badge-success' :
              call.user_sentiment.toLowerCase() === 'negative' ? 'badge-error' :
              'badge-warning'
            }">
              ${call.user_sentiment}
            </span>
            ` : '<span class="text-surface-500">N/A</span>'}
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-surface-400">Call Transferred</dt>
          <dd class="text-surface-200">${call.call_transferred ? 'Yes' : 'No'}</dd>
        </div>
        ${call.from_number ? `
        <div class="flex justify-between">
          <dt class="text-surface-400">From Number</dt>
          <dd class="text-surface-200">${call.from_number}</dd>
        </div>
        ` : ''}
        ${call.to_number ? `
        <div class="flex justify-between">
          <dt class="text-surface-400">To Number</dt>
          <dd class="text-surface-200">${call.to_number}</dd>
        </div>
        ` : ''}
      </dl>
    </div>
  </div>

  <!-- Transcript -->
  ${call.transcript ? `
  <div class="card">
    <h2 class="text-lg font-semibold text-surface-100 mb-4">Transcript</h2>
    <div class="bg-surface-950 rounded-lg p-4 max-h-96 overflow-y-auto">
      <pre class="text-sm text-surface-300 whitespace-pre-wrap font-mono">${call.transcript}</pre>
    </div>
  </div>
  ` : ''}

  <!-- Post Call Analysis -->
  ${call.call_analysis ? `
  <div class="card">
    <h2 class="text-lg font-semibold text-surface-100 mb-4">Post-Call Analysis</h2>
    <div class="bg-surface-950 rounded-lg p-4">
      <pre class="text-sm text-surface-300 whitespace-pre-wrap">${JSON.stringify(call.call_analysis, null, 2)}</pre>
    </div>
  </div>
  ` : ''}
</div>
` }) %>

