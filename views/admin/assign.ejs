<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Back link -->
  <a href="/admin/users" class="inline-flex items-center gap-2 text-surface-400 hover:text-surface-200 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Users
  </a>

  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-surface-50">Assign Agents</h1>
    <p class="text-surface-400 mt-1">
      Select agents to assign to <span class="text-surface-200 font-medium">${targetUser.name}</span>
    </p>
  </div>

  <!-- User Info Card -->
  <div class="card">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-brand-600/20 flex items-center justify-center text-brand-400 text-xl font-medium">
        ${targetUser.name.charAt(0).toUpperCase()}
      </div>
      <div>
        <h2 class="text-lg font-semibold text-surface-100">${targetUser.name}</h2>
        <p class="text-surface-400">${targetUser.email}</p>
      </div>
      <span class="badge ${targetUser.role === 'admin' ? 'badge-warning' : 'badge-info'} ml-auto">
        ${targetUser.role}
      </span>
    </div>
  </div>

  <!-- Agent Selection Form -->
  <form action="/admin/users/${targetUser._id}/assign" method="POST" class="space-y-6">
    <div class="card">
      <h3 class="text-lg font-semibold text-surface-100 mb-4">Available Agents</h3>
      
      ${agents.length === 0 ? `
      <div class="text-center py-8">
        <svg class="w-12 h-12 mx-auto mb-4 text-surface-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        <p class="text-surface-400">No agents available. Create agents in Retell AI first.</p>
      </div>
      ` : `
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        ${agents.map(agent => `
        <label class="flex items-start gap-4 p-4 rounded-lg border border-surface-700 hover:border-surface-600 cursor-pointer transition-colors ${agent.isAssigned ? 'bg-brand-600/5 border-brand-600/30' : ''}">
          <input 
            type="checkbox" 
            name="agents" 
            value="${agent.agent_id}"
            ${agent.isAssigned ? 'checked' : ''}
            class="mt-1 w-5 h-5 rounded border-surface-600 bg-surface-800 text-brand-600 focus:ring-brand-500 focus:ring-offset-surface-900"
          >
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-medium text-surface-100 truncate">${agent.agent_name || 'Unnamed Agent'}</span>
              ${agent.is_published ? '<span class="badge badge-success text-xs">Published</span>' : ''}
            </div>
            <p class="text-xs text-surface-500 font-mono mt-1">${agent.agent_id.substring(0, 20)}...</p>
            <div class="flex items-center gap-4 mt-2 text-xs text-surface-400">
              <span>${agent.language || 'en-US'}</span>
              <span>${agent.voice_id || 'Default voice'}</span>
            </div>
          </div>
        </label>
        `).join('')}
      </div>
      `}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <button type="submit" class="btn btn-primary">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Save Assignments
      </button>
      <a href="/admin/users" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
` }) %>

