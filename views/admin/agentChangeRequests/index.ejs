<%- include('../../layouts/main', { body: `
<div class="space-y-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-surface-50">Agent change requests</h1>
      <p class="text-surface-400 mt-1">Support-style queue: open tickets first, then full history (pending + completed).</p>
    </div>
    <a href="/admin/users" class="btn btn-secondary">Back to Users</a>
  </div>

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>Status</th>
          <th>User</th>
          <th>Agent</th>
          <th>Details</th>
          <th>Created</th>
          <th>Updated</th>
          <th>Completed</th>
          <th>By</th>
          <th class="text-right">Action</th>
        </tr>
      </thead>
      <tbody>
        ${requests.length === 0 ? `
          <tr>
            <td colspan="9" class="text-center py-12 text-surface-400">
              No requests yet.
            </td>
          </tr>
        ` : requests.map(r => `
          <tr class="${r.status === 'pending' ? 'bg-brand-500/5' : ''}">
            <td>
              ${r.status === 'pending'
                ? '<span class="badge badge-warning">pending</span>'
                : '<span class="badge badge-success">completed</span>'}
            </td>
            <td>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-brand-600/20 flex items-center justify-center text-brand-400 font-medium">
                  ${r.user?.name ? r.user.name.charAt(0).toUpperCase() : '?'}
                </div>
                <div>
                  <div class="font-medium text-surface-100">${r.user?.name || 'Unknown user'}</div>
                  <div class="text-sm text-surface-400">${r.user?.email || ''}</div>
                </div>
              </div>
            </td>
            <td>
              <div class="text-surface-200 font-medium">
                ${agentNameMap && agentNameMap[r.requestedAgentId] ? agentNameMap[r.requestedAgentId] : r.requestedAgentId}
              </div>
              <div class="text-xs text-surface-500 font-mono mt-1 break-all">${r.requestedAgentId}</div>
            </td>
            <td class="text-surface-400 max-w-[220px]">
              ${r.reason ? r.reason.substring(0, 120) + (r.reason.length > 120 ? '...' : '') : '—'}
            </td>
            <td class="text-surface-400 whitespace-nowrap text-xs">
              ${r.createdAt ? new Date(r.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'}
            </td>
            <td class="text-surface-400 whitespace-nowrap text-xs">
              ${r.updatedAt ? new Date(r.updatedAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'}
            </td>
            <td class="text-surface-400 whitespace-nowrap text-xs">
              ${r.status === 'completed' && r.completedAt
                ? new Date(r.completedAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
                : '—'}
            </td>
            <td class="text-surface-400 text-xs">
              ${r.completedByUser?.name || (r.completedByUser?.email ? r.completedByUser.email : '—')}
            </td>
            <td class="text-right">
              ${r.status === 'pending' ? `
              <form action="/admin/agent-change-requests/${r._id}/complete" method="POST" class="inline"
                onsubmit="return confirm('Complete this ticket and apply the requested agent to the user?')">
                <button type="submit" class="btn btn-primary text-sm py-1.5 px-3">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Complete
                </button>
              </form>
              ` : '<span class="text-surface-500 text-xs">—</span>'}
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  </div>
</div>
` }) %>
