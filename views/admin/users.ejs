<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-surface-50">User Management</h1>
    <p class="text-surface-400 mt-1">Manage users and their agent assignments</p>
  </div>

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  <!-- Users Table -->
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>Agents</th>
          <th>Joined</th>
          <th>Last Login</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        ${users.length === 0 ? `
        <tr>
          <td colspan="6" class="text-center py-12 text-surface-400">
            No users found
          </td>
        </tr>
        ` : users.map(u => `
        <tr>
          <td>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-brand-600/20 flex items-center justify-center text-brand-400 font-medium">
                ${u.name.charAt(0).toUpperCase()}
              </div>
              <div>
                <div class="font-medium text-surface-100">${u.name}</div>
                <div class="text-sm text-surface-400">${u.email}</div>
              </div>
            </div>
          </td>
          <td>
            <span class="badge ${u.role === 'admin' ? 'badge-warning' : 'badge-info'}">
              ${u.role}
            </span>
          </td>
          <td>
            <div class="flex items-center gap-2">
              <span class="text-surface-200">${u.agentCount}</span>
              <span class="text-surface-500">agent${u.agentCount !== 1 ? 's' : ''}</span>
            </div>
            ${u.agentNames.length > 0 ? `
            <div class="text-xs text-surface-500 mt-1">
              ${u.agentNames.join(', ')}${u.agentCount > 3 ? '...' : ''}
            </div>
            ` : ''}
          </td>
          <td class="text-surface-400">
            ${new Date(u.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </td>
          <td class="text-surface-400">
            ${u.lastLogin ? new Date(u.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Never'}
          </td>
          <td>
            <div class="flex items-center justify-end gap-2">
              <a href="/admin/users/${u._id}/assign" class="btn btn-secondary text-sm py-1.5 px-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                </svg>
                Assign
              </a>
              ${u._id.toString() !== user.id ? `
              <form action="/admin/users/${u._id}/toggle-role" method="POST" class="inline">
                <button type="submit" class="btn btn-secondary text-sm py-1.5 px-3" title="Toggle role">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                  </svg>
                </button>
              </form>
              <form action="/admin/users/${u._id}/delete" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this user?')">
                <button type="submit" class="btn btn-danger text-sm py-1.5 px-3" title="Delete user">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </form>
              ` : `
              <span class="text-xs text-surface-500 px-2">(You)</span>
              `}
            </div>
          </td>
        </tr>
        `).join('')}
      </tbody>
    </table>
  </div>
</div>
` }) %>

