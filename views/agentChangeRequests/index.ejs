<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-surface-50">Agent change request</h1>
    <p class="text-surface-400 mt-1">
      You can only open a ticket for agents <span class="text-surface-200">already assigned to you</span>.
      Your open ticket stays <span class="text-surface-200">pending</span> until an admin marks it complete. You can edit it anytime while it is open.
    </p>
  </div>

  ${success ? `
  <div class="p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-lg">
    <p class="text-sm text-emerald-400">Request submitted. It is open as <strong>pending</strong> — you can edit it below until an admin completes it.</p>
  </div>
  ` : ''}

  ${updated ? `
  <div class="p-4 bg-cyan-500/10 border border-cyan-500/20 rounded-lg">
    <p class="text-sm text-cyan-400">Your open request was updated.</p>
  </div>
  ` : ''}

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  ${agents.length === 0 ? `
  <div class="card">
    <p class="text-surface-300">You have no agents assigned yet. Contact an administrator before you can submit a change request.</p>
    <a href="/agents" class="btn btn-secondary mt-4 inline-flex">Back to Agents</a>
  </div>
  ` : `
  <div class="card">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h2 class="text-lg font-semibold text-surface-100">
          ${pendingRequest ? 'Your open request (pending)' : 'New request'}
        </h2>
        <p class="text-sm text-surface-400 mt-1">
          ${pendingRequest
            ? 'Update the agent or details below, then save. This replaces your current open ticket.'
            : 'Submit a ticket. After submit, it appears below as pending until an admin completes it.'}
        </p>
      </div>
      ${pendingRequest ? `
      <span class="badge badge-warning shrink-0">Open · pending</span>
      ` : ''}
    </div>

    <form action="/agent-change-requests" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="label">Your assigned agent IDs</label>
          <div class="text-sm text-surface-200 font-mono break-all">
            ${assignedAgentIds && assignedAgentIds.length > 0
              ? assignedAgentIds.join(', ')
              : 'None'}
          </div>
        </div>

        <div>
          <label class="label">Agent this request is about</label>
          <select name="requestedAgentId" class="input text-sm" required>
            <option value="">Select one of your assigned agents...</option>
            ${agents.map(a => `
              <option value="${a.agent_id}" ${pendingRequest && pendingRequest.requestedAgentId === a.agent_id ? 'selected' : ''}>
                ${a.agent_name || a.agent_id.substring(0, 16)} (${a.agent_id.substring(0, 12)}...)
              </option>
            `).join('')}
          </select>
        </div>
      </div>

      <div>
        <label class="label">Details (optional)</label>
        <textarea
          name="reason"
          class="input"
          rows="4"
          placeholder="Describe the change you need (optional)."
        >${typeof pendingReasonEscaped !== 'undefined' ? pendingReasonEscaped : ''}</textarea>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <button type="submit" class="btn btn-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          ${pendingRequest ? 'Save changes' : 'Submit request'}
        </button>
        <a href="/agents" class="btn btn-secondary">Back to Agents</a>
      </div>
    </form>
  </div>
  `}

  <!-- Ticket history (all your requests) -->
  <div>
    <h2 class="text-lg font-semibold text-surface-100 mb-3">Your ticket history</h2>
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Agent</th>
            <th>Status</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Completed</th>
            <th>Details</th>
          </tr>
        </thead>
        <tbody>
          ${requests.length === 0 ? `
            <tr>
              <td colspan="6" class="text-center py-12 text-surface-400">
                No tickets yet.
              </td>
            </tr>
          ` : requests.map(r => `
            <tr class="${r.status === 'pending' ? 'bg-brand-500/5' : ''}">
              <td class="text-surface-200">
                <div class="font-medium">
                  ${agentNameMap && agentNameMap[r.requestedAgentId] ? agentNameMap[r.requestedAgentId] : r.requestedAgentId}
                </div>
                <div class="text-xs text-surface-500 font-mono mt-0.5">${r.requestedAgentId}</div>
              </td>
              <td>
                ${r.status === 'pending'
                  ? '<span class="badge badge-warning">pending</span>'
                  : '<span class="badge badge-success">completed</span>'}
              </td>
              <td class="text-surface-400 whitespace-nowrap">
                ${r.createdAt ? new Date(r.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'}
              </td>
              <td class="text-surface-400 whitespace-nowrap">
                ${r.updatedAt ? new Date(r.updatedAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'}
              </td>
              <td class="text-surface-400 whitespace-nowrap">
                ${r.status === 'completed' && r.completedAt
                  ? new Date(r.completedAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' })
                  : '—'}
              </td>
              <td class="text-surface-400 max-w-[280px]">
                ${r.reason ? r.reason.substring(0, 100) + (r.reason.length > 100 ? '...' : '') : '-'}
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  </div>
</div>
` }) %>
