<%- include('../layouts/main', { body: `
<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-surface-50">Request Agent Change</h1>
    <p class="text-surface-400 mt-1">
      Choose the agent you want to use next. An admin will review and complete your request.
    </p>
  </div>

  ${success ? `
  <div class="p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-lg">
    <p class="text-sm text-emerald-400">Request submitted successfully. Waiting for admin approval.</p>
  </div>
  ` : ''}

  ${typeof error !== 'undefined' && error ? `
  <div class="p-4 bg-amber-500/10 border border-amber-500/20 rounded-lg">
    <p class="text-sm text-amber-400">${error}</p>
  </div>
  ` : ''}

  <!-- Request Form -->
  <div class="card">
    <form action="/agent-change-requests" method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="label">Current assigned agent(s)</label>
          <div class="text-sm text-surface-200">
            ${assignedAgentIds && assignedAgentIds.length > 0
              ? assignedAgentIds.join(', ')
              : 'None assigned'}
          </div>
        </div>

        <div>
          <label class="label">Requested agent</label>
          <select name="requestedAgentId" class="input text-sm" required>
            <option value="">Select an agent...</option>
            ${agents.map(a => `
              <option value="${a.agent_id}">
                ${a.agent_name || a.agent_id.substring(0, 16)} (${a.agent_id.substring(0, 12)}...)
              </option>
            `).join('')}
          </select>
        </div>
      </div>

      <div>
        <label class="label">Reason (optional)</label>
        <textarea
          name="reason"
          class="input"
          rows="4"
          placeholder="Tell admin what you want to change and why (optional)."
        ></textarea>
      </div>

      <div class="flex items-center gap-4">
        <button type="submit" class="btn btn-primary">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14m7-7H5" />
          </svg>
          Submit Request
        </button>
        <a href="/agents" class="btn btn-secondary">Back to Agents</a>
      </div>
    </form>
  </div>

  <!-- Recent Requests -->
  <div class="table-container">
    <table class="table">
      <thead>
        <tr>
          <th>Requested Agent</th>
          <th>Status</th>
          <th>Created</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        ${requests.length === 0 ? `
          <tr>
            <td colspan="4" class="text-center py-12 text-surface-400">
              No requests yet.
            </td>
          </tr>
        ` : requests.map(r => `
          <tr>
            <td class="text-surface-200">
              ${r.requestedAgentId}
            </td>
            <td>
              ${r.status === 'pending'
                ? '<span class="badge badge-warning">pending</span>'
                : '<span class="badge badge-success">completed</span>'}
            </td>
            <td class="text-surface-400">
              ${r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '-'}
            </td>
            <td class="text-surface-400 max-w-[360px]">
              ${r.reason ? r.reason.substring(0, 80) + (r.reason.length > 80 ? '...' : '') : '-'}
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  </div>
</div>
` }) %>

