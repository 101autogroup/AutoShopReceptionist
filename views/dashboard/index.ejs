          }
        },
        onHover: function(event, elements) {
          event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
        }
      }
    });
    if (containerId) markChartLoaded(containerId);
    return chart;
  }

  // Create horizontal bar chart for agents
  function createHorizontalBarChart(ctx, data, color, containerId, maxValue) {
    var chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: chartData.agentLabels,
        datasets: [{
          data: data,
          backgroundColor: color,
          borderRadius: 4,
          barThickness: isMobile ? 16 : 20
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        interaction: {
          mode: 'index',
          intersect: false
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            ...interactiveTooltip,
            callbacks: {
              label: function(context) {
                return context.parsed.x.toFixed(1) + '%';
              }
            }
          }
        },
        scales: {
          x: {
            beginAtZero: true,
            max: maxValue || 100,
            grid: { color: 'rgba(51, 65, 85, 0.3)' },
            ticks: {
              font: { size: isMobile ? 8 : 10 },
              callback: function(value) { return value + '%'; }
            }
          },
          y: {
            grid: { display: false },
            ticks: {
              font: { size: isMobile ? 8 : 10 },
              callback: function(value, index) {
                var label = this.getLabelForValue(value);
                return label.length > 12 ? label.substring(0, 12) + '...' : label;
              }
            }
          }
        },
        onHover: function(event, elements) {
          event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
        }
      }
    });
    if (containerId) markChartLoaded(containerId);
    return chart;
  }

  // Create area chart for trends
  function createAreaChart(ctx, data, color, alphaColor, containerId) {
    var chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: chartData.labels,
        datasets: [{
          data: data,
          borderColor: color,
          backgroundColor: alphaColor,
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          pointHoverRadius: 5,
          pointHoverBackgroundColor: color,
          pointHoverBorderColor: '#fff',
          pointHoverBorderWidth: 2,
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false
        },
        plugins: {
          legend: { display: false },
          tooltip: interactiveTooltip
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              maxRotation: 0,
              autoSkip: true,
              maxTicksLimit: isMobile ? 4 : 6,
              font: { size: isMobile ? 8 : 10 }
            }
          },
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(51, 65, 85, 0.3)' },
            ticks: { font: { size: isMobile ? 8 : 10 } }
          }
        },
        onHover: function(event, elements) {
          event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
        }
      }
    });
    if (containerId) markChartLoaded(containerId);
    return chart;
  }

  // Create donut chart
  function createDonutChart(ctx, labels, data, bgColors, containerId) {
    var chart = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
          data: data,
          backgroundColor: bgColors,
          borderWidth: 0,
          hoverOffset: 8,
          hoverBorderWidth: 2,
          hoverBorderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '65%',
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              padding: isMobile ? 8 : 12,
              usePointStyle: true,
              pointStyle: 'circle',
              font: { size: isMobile ? 9 : 10 }
            }
          },
          tooltip: {
            ...interactiveTooltip,
            callbacks: {
              label: function(context) {
                var total = context.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                var percentage = total > 0 ? ((context.parsed / total) * 100).toFixed(1) : 0;
                return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
              }
            }
          }
        },
        onHover: function(event, elements) {
          event.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
        }
      }
    });
    if (containerId) markChartLoaded(containerId);
    return chart;
  }

